# ============================================================
# Tel Intern Backend — Environment Variables
# ============================================================
# CARA PAKAI:
#   1. Salin file ini menjadi .env   (copy .env.example .env)
#   2. Isi nilai SUPABASE_URL dan SUPABASE_SERVICE_KEY
#      dari dashboard Supabase → Settings → API
#   3. Jangan pernah commit file .env ke git!
# ============================================================

# JWT — ganti dengan string acak panjang di production!
JWT_SECRET=RAHASIA_SUPER_KUAT_GANTI_INI_SEKARANG_2026!

# Port server
PORT=3001

# ── SUPABASE ──────────────────────────────────────────────
# Dapatkan dari: https://supabase.com/dashboard → project → Settings → API

# Project URL (contoh: https://xyzabc.supabase.co)
SUPABASE_URL=

# Service Role Key — RAHASIA! Jangan expose ke frontend
# (bukan anon key, tapi service_role key)
SUPABASE_SERVICE_KEY=
